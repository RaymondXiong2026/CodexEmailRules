# Runtime
NODE_ENV=development
APP_NAME=codex-email-rules-extension
LOG_LEVEL=info

# API
API_BASE_URL=http://localhost:3000/api

# SMTP sender pool (JSON Array)
# [{"name":"store-1","host":"smtp.gmail.com","port":587,"secure":false,"user":"noreply@store.com","pass":"***","fromName":"Store Service","fromEmail":"noreply@store.com"}]
SMTP_ACCOUNTS=[]
SMTP_DEFAULT_ACCOUNT=store-1
SMTP_SIGNATURE=<br/><br/>Best regards,<br/>Store Customer Service Team
SMTP_MAX_RETRY=4
SMTP_RETRY_BASE_MS=500
SMTP_ALERT_WEBHOOK=

# ERP
ERP_PROVIDER=generic
ERP_BASE_URL=https://erp.example.com
ERP_API_KEY=replace-me
ERP_TIMEOUT_MS=8000
ERP_MAX_RETRY=3
ERP_RETRY_BASE_MS=700
ERP_FAILURE_CACHE_FILE=./data/cache/erp-failures.json

# Field mapping: JSON object
# {"orderNo":"erp_order_id","customerEmail":"email","amount":"total_amount"}
ERP_FIELD_MAPPING={}
