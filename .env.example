# Runtime
APP_ENV=prod
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=60

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=shop_mail_ai

# OpenAI via simple-openai
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=30

# IMAP store configs: JSON array
# [{"store_id":"store_a","email":"a@example.com","password":"xxx","imap_host":"imap.gmail.com","imap_port":993,"folder":"INBOX"}]
IMAP_STORES_JSON=[]

# Rule file
WORKFLOW_RULES_PATH=config/workflow_rules.yaml
