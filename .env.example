PORT=3000
DB_PATH=./data/app.db

# SMTP 配置（用于真实发邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_user
SMTP_PASS=your_pass
SMTP_SECURE=true
MAIL_FROM=service@example.com

# ERP 接口配置
ERP_BASE_URL=https://erp.example.com
ERP_API_KEY=replace_with_api_key
ERP_TIMEOUT_MS=10000

# 定时任务 CRON（默认每 5 分钟扫描一次）
CRON_REVIEW_SCAN=*/5 * * * *
